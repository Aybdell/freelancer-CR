# Database (MySQL / MariaDB) — must be a remote host for Vercel (not localhost)
# Examples: PlanetScale, Railway, Aiven, or your own hosted MySQL server
DATABASE_URL="mysql://user:password@host:3306/freelancer_crm"

# NextAuth — generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="https://your-app.vercel.app"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
